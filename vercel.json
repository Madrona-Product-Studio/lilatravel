{
  "functions": {
    "api/generate-itinerary.js": {
      "includeFiles": "src/data/destinations/**,prompts/**,src/services/**",
      "maxDuration": 180
    },
    "api/refine-itinerary.js": {
      "includeFiles": "prompts/**",
      "maxDuration": 180
    },
    "api/generate-alternatives.js": {
      "includeFiles": "src/data/destinations/**,prompts/**,src/services/**",
      "maxDuration": 60
    },
    "api/extract-booking.js": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ]
}
